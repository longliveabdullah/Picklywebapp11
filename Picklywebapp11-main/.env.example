# Supabase (required for auth and data)
# Copy this file to .env.local and fill in your project values from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Python price service (local dev: run price-service on port 8001)
PRICE_SERVICE_URL=http://localhost:8001

# Optional: for server-side admin operations (e.g. createServerSupabaseClient)
# SUPABASE_SERVICE_ROLE_KEY=

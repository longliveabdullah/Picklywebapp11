# Copy to .env.local and fill in values. Never commit real keys.

# --- Supabase (required for auth and data)
# Dashboard: Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# --- Python price service (local dev URL must match uvicorn PORT)
PRICE_SERVICE_URL=http://localhost:8001

# --- AI routing (OpenRouter-compatible; supply one key — not both)
# OPENROUTER_API_KEY=
# OPENAI_API_KEY=

# --- Optional Supabase admin (never expose client-side)
# SUPABASE_SERVICE_ROLE_KEY=

# --- Optional: public site URL (OpenRouter referrer / links)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Optional: overrides default LLM model id
# PICKLY_OPENROUTER_MODEL=openai/gpt-4.1-mini

# --- Playwright E2E: fixed password only if needed; tests generate one if unset
# E2E_TEST_PASSWORD=
